    6             dst_mac = string.lower(station.station_mac),
    6             signal = station_stats.signal,
    6             chains = station_stats.chains,
    6             iface = station.iface,
    6             rx_rate = station_stats.rx_rate,
    6             tx_rate = station_stats.tx_rate,
    6             freq = freq,
    6             channel = chanenel,
                  --dst_loc = {lat="FIXME",long="FIXME"} --if no location is found later no dst location will be informed
    6         }
          end
    4     return links
      end

